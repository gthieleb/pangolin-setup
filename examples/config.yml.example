# Pangolin Configuration
# https://docs.pangolin.net/

gerbil:
  start_port: 51820
  # ANPASSEN: Deine Dashboard-Domain
  base_endpoint: "dashboard.apps.deine-domain.de"

app:
  # ANPASSEN: Deine Dashboard-URL
  dashboard_url: "https://dashboard.apps.deine-domain.de"
  log_level: "info"
  telemetry:
    anonymous_usage: true

domains:
  domain1:
    # ANPASSEN: Deine Base-Domain für Services
    base_domain: "apps.deine-domain.de"

server:
  # ANPASSEN: Generiere mit: openssl rand -hex 32
  secret: "DEIN_SERVER_SECRET_HIER_EINFUEGEN"
  cors:
    # ANPASSEN: Deine Dashboard-Domain
    origins: ["https://dashboard.apps.deine-domain.de"]
    methods: ["GET", "POST", "PUT", "DELETE", "PATCH"]
    allowed_headers: ["X-CSRF-Token", "Content-Type"]
    credentials: false

flags:
  require_email_verification: false
  disable_signup_without_invite: true
  disable_user_create_org: false
  allow_raw_resources: true
