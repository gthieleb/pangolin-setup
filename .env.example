# Cloudflare DNS-01 Challenge Credentials
# ========================================
# 
# Erstelle einen API Token bei: https://dash.cloudflare.com/profile/api-tokens
# Benötigte Berechtigungen:
#   - Zone:Read
#   - DNS:Edit
# Zone Resources: Include - Specific zone - deine-domain.de
#
# ODER verwende den Global API Key (weniger sicher):
#   CF_API_EMAIL=deine-email@beispiel.de
#   CF_API_KEY=dein-global-api-key

CF_DNS_API_TOKEN=dein-cloudflare-api-token-hier-einfuegen
# CF_API_EMAIL=
# CF_API_KEY=
